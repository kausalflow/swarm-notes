---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import { getCollection } from 'astro:content';

const allVaultEntries = await getCollection('vault');

// Group entries by top-level folder
const folders: Record<string, any[]> = {};
allVaultEntries.forEach(entry => {
  const vaultIndex = entry.filePath?.indexOf('vault/');
  const realSlug = (entry.filePath && vaultIndex !== -1) 
    ? entry.filePath.substring(vaultIndex + 6).replace(/\.md$/, '') 
    : entry.id;

  const parts = realSlug.split('/');
  const folder = parts.length > 1 ? parts[0] : 'Root';
  if (!folders[folder]) folders[folder] = [];
  folders[folder].push({ entry, realSlug });
});
---

<BaseLayout title="Vault Catalog" description="Knowledge Vault and Swarm Cruise Website Hosted by AstroDeck">
  <Hero
    badge="Knowledge Base"
    title="Swarm Cruise Vault"
    subtitle="Explore the interconnected markdown notes, concepts, and ArXiV papers parsed securely from the vault directory."
  />

  <div class="container py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {Object.entries(folders).map(([folder, items]) => (
        <div class="rounded-xl border bg-card text-card-foreground shadow-sm flex flex-col hover:border-primary/50 transition-colors duration-300">
          <div class="p-6 pb-4 border-b bg-muted/20">
            <h2 class="text-2xl font-semibold leading-none tracking-tight capitalize">
              {folder}
            </h2>
            <p class="text-sm text-muted-foreground mt-2">{items.length} Articles</p>
          </div>
          <div class="p-6 max-h-96 overflow-y-auto">
            <ul class="space-y-3">
              {items.map(({ entry, realSlug }) => (
                <li>
                  <a href={`/${realSlug}/`} class="group flex items-center justify-between text-sm hover:text-primary transition-colors">
                    <span class="truncate pr-4 flex-1">{entry.data?.title || realSlug.split('/').pop()}</span>
                    <svg class="h-4 w-4 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all text-primary flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
